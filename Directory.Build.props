<Project>

  <!-- Shared build settings for every project in the solution. -->
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Surface the editorconfig style rules as build warnings, not just IDE hints. -->
    <!-- Flip TreatWarningsAsErrors to true (e.g. in CI) for a hard gate. -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>

    <!-- Emit XML docs for the public API; CS1591 (missing doc) is not enforced. -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <!-- NuGet package metadata shared by the publishable projects (SolSharp.Core, SolSharp.Rpc).
       Test projects set IsPackable=false and are unaffected. PackageId defaults to the assembly
       name; each project supplies its own Description. Set RepositoryUrl / PackageProjectUrl
       once the repository is public. -->
  <PropertyGroup Label="Package metadata">
    <Version>0.1.0-alpha</Version>
    <Authors>yevhen</Authors>
    <Product>SolSharp</Product>
    <Copyright>Copyright (c) 2026 yevhen</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>solana;web3;blockchain;rpc;crypto;defi</PackageTags>
    <RepositoryType>git</RepositoryType>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <!-- Pack the shared README into every publishable package. -->
  <ItemGroup Condition="'$(IsPackable)' != 'false'">
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

</Project>
